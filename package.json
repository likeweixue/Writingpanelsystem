{
  "name": "WritingPanelSystem",
  "version": "v 1.9.3",
  "description": "写作帮手 - 免费的写作软件",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "author": "麻昌生",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.WritingPanelSystem.app",
    "productName": "WritingPanelSystem",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "files": [
      "**/*",
      "!node_modules",
      "!dist"
    ]
  }
}